# Backend environment variables
PORT=3000
EMAIL_DELIVERY_MODE=smtp
DATABASE_PATH=dopablocker.db
FIREBASE_PROJECT_ID=dopablocker-dev
SQLCIPHER_KEY=dev-only-unsafe-key

# Email verification codes. Use strong secrets in production.
# Use EMAIL_DELIVERY_MODE=log for local development without a real SMTP account.
EMAIL_CODE_SECRET=replace-with-random-secret

# SMTP provider default: Resend (https://resend.com/api-keys).
# onboarding@resend.dev e o remetente de teste gratuito; em modo sandbox
# ele so entrega para o email da conta Resend. Para enviar a qualquer
# destinatario, verifique um dominio proprio em Resend -> Domains.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_replace_with_resend_api_key
SMTP_FROM="DopaBlocker <onboarding@resend.dev>"

RUST_LOG=info

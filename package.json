{
  "name": "dopablocker",
  "private": true,
  "version": "0.1.0",
  "description": "DopaBlocker monorepo — block distractions, unlock productivity",
  "scripts": {
    "dev:desktop": "pnpm --dir desktop run dev",
    "build:desktop": "pnpm --dir desktop run build",
    "tauri:dev": "pnpm --dir desktop exec tauri dev",
    "tauri:build": "pnpm --dir desktop exec tauri build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}

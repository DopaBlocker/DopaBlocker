# Copie este arquivo para `.env` e preencha com os valores do seu projeto Firebase.
# Console: https://console.firebase.google.com → Project Settings → General →
# "Your apps" → "Web app" → SDK setup and configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MSG_SENDER_ID=

# Base do backend Axum local. Normalmente não precisa mudar.
VITE_API_URL=http://localhost:3000
